  "editUrl": "https://github.com/floruntime/docs/edit/main/docs",
  "ai": {
    "enabled": true,
    "mode": "proxy",
    "provider": "openrouter",
    "model": "deepseek/deepseek-v4-flash",
    "endpoint": "https://ask.floruntime.io",
    "suggestions": true,
    "label": "Ask AI",
    "maxTokens": 1024,
    "rateLimit": { "perMinute": 10 }
  },
  "seo": {
    "title": "Flo — The Universal Distributed Runtime",
    "description": "Flo unifies streams, key-value storage, queues, time-series, actions, workflows, and stream processing in a single binary. Thread-per-shard, Raft-replicated, zero dependencies."
  }
